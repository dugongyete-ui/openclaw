modules = ["nodejs-20", "swift-5.8", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Gateway Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ui && node node_modules/.bin/vite"
waitForPort = 5000

[[workflows.workflow]]
name = "Gateway Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node gateway-server.js"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "cd ui && node node_modules/.bin/vite build"]
publicDir = "dist/control-ui"
